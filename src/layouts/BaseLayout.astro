---
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = "校园超艺术托马森观察档案",
  description = "社会调查与研究方法课程 · 校园田野作品集"
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
